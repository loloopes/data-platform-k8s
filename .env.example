# Copy to k8s/.env and customize. Used by scripts/build-images.sh and secretGenerator.

# Postgres (MLflow)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow

# MinIO
MINIO_ROOT_USER=minio123
MINIO_ROOT_PASSWORD=minio123
MLFLOW_BUCKET=mlflow
HIVE_WAREHOUSE_BUCKET=lakehouse

# AWS / S3 (MinIO)
# MinIO S3 API (inside the cluster — NOT your AWS account credentials)
AWS_ACCESS_KEY_ID=minio123
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1

# MLflow
MLFLOW_TRACKING_USERNAME=admin
MLFLOW_TRACKING_PASSWORD=password1234
MLFLOW_FLASK_SERVER_SECRET_KEY=change-me-set-a-long-random-secret
MLFLOW_SERVER_ALLOWED_HOSTS=mlflow,mlflow.local,data-platform.svc.cluster.local,localhost:*,127.0.0.1:*
MLFLOW_MODEL_URI=models:/credit_riks_forecast/1
RUN_ID=
MLFLOW_MODEL_ARTIFACT_PATH=credit_model_pipeline_v2
MLFLOW_MODEL_NAME=credit_riks_forecast
MLFLOW_MODEL_STAGE=latest

# Hive metastore MySQL
MYSQL_ROOT_PASSWORD=admin
MYSQL_USER=admin
MYSQL_PASSWORD=admin
MYSQL_DATABASE=metastore_db

# pgvector (Trino PostgreSQL catalog + vector search)
PGVECTOR_USER=vector
PGVECTOR_PASSWORD=vector
PGVECTOR_DB=vectors

# Airflow
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnilv8q8FZ8jU2Ulf6fqoKQM=
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=airflow

# Trino MCP
TRINO_USER=admin
TRINO_PASSWORD=

# LLM (required for llm-api / langgraph)
HF_TOKEN=
BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
ADAPTER_REPO=Glccampos/llm_qween
SKIP_PREFETCH=true

# LangSmith (langgraph)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=llm-langgraph

# Image tags (local builds)
IMAGE_TAG=latest
